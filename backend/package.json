{
  "name": "ecommerce-detail-backend",
  "version": "1.0.0",
  "description": "电商详情图生成系统后端",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:sync": "tsx src/scripts/sync-db.ts",
    "db:rebuild": "set CONFIRM_REBUILD=yes& tsx rebuild-db.ts",
    "test:e2e": "node e2e-test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.12.0",
    "openai": "^4.85.0",
    "sequelize": "^6.37.5",
    "sharp": "^0.33.5",
    "uuid": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
