# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_detail
DB_USER=root
DB_PASSWORD=your_password

# 胜算云中转平台 (GPT-5.5 / GPT Image 2，已停用，保留备用)
SSY_BASE_URL=https://router.shengsuanyun.com/api/v1
SSY_API_KEY=your_ssy_api_key

# 柴犬平台 (GPT Image 2 同步生图)
CHAIQUAN_BASE_URL=https://image.wucur.com
CHAIQUAN_API_KEY=your_chaiquan_api_key

# 柴犬平台 (GPT-5.5 LLM 聊天)
CHAIQUAN_LLM_BASE_URL=https://api.2000.run/v1
CHAIQUAN_LLM_API_KEY=your_chaiquan_llm_api_key

# 火山引擎 ARK (Seedream 5.0，已停用，保留备用)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=your_ark_api_key

# 阿里百炼 (qwen3.5-plus LLM + 多模态视觉理解)
BAILIAN_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
BAILIAN_API_KEY=your_bailian_api_key

# 阿里百炼图像生成 (qwen-image-2.0 系列)
BAILIAN_IMAGE_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/api/v1/services/aigc/multimodal-generation
BAILIAN_IMAGE_API_KEY=your_bailian_image_api_key
BAILIAN_IMAGE_MODEL=qwen-image-2.0-2026-03-03

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=20971520
